{
  "outputDirectory": "public",
  "framework": null,
  "buildCommand": "bash vercel-build.sh",
  "installCommand": "echo 'composer install handled in buildCommand'",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 60
    },
    "api/cron/scheduler.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduler?token=__CRON_SECRET__",
      "schedule": "0 0 * * *"
    }
  ],
  "regions": ["sin1"]
}
