{
  "outputDirectory": "public",
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 60
    },
    "api/cron/scheduler.php": {
      "runtime": "vercel-php@0.8.0",
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/scheduler?token=__CRON_SECRET__",
      "schedule": "0 0 * * *"
    }
  ],
  "regions": ["sin1"]
}
