{
  "outputDirectory": "public",
  "framework": null,
  "buildCommand": "php artisan package:discover --ansi && php artisan optimize:clear --ansi",
  "installCommand": "echo 'Skip npm install'",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
