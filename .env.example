APP_NAME=KomunaID
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (external MySQL, e.g. Hostinger) ──────────────────
DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=komunaid
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# ── Drivers: use database (serverless filesystem is read-only) ──
CACHE_DRIVER=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── File storage: Cloudflare R2 (S3-compatible) in production ───
# Set PUBLIC_DISK_DRIVER=s3 in production; leave 'local' for dev.
PUBLIC_DISK_DRIVER=s3
# Public base URL of the bucket (r2.dev URL or your custom domain), no trailing slash.
PUBLIC_DISK_URL=https://pub-xxxxxxxx.r2.dev
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_DEFAULT_REGION=auto
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
